{
  "name": "hero-quiz-functions",
  "version": "1.0.0",
  "description": "용사 퀴즈 앱 Cloud Functions",
  "main": "lib/index.js",
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs'),p=require('path');const d=p.join(__dirname,'src/shared');fs.mkdirSync(d,{recursive:true});['expRewards.json','courseChapters.json'].forEach(f=>fs.copyFileSync(p.join(__dirname,'../shared',f),p.join(d,f)))\"",
    "build": "npm run prebuild && tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "lint": "eslint --ext .ts src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@google-cloud/vision": "^4.3.2",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.2.2",
    "google-auth-library": "^9.6.0",
    "jimp": "^0.22.12",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.9.8"
  },
  "devDependencies": {
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^6.4.14",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "private": true
}
