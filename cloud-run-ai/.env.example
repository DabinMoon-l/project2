# Cloud Run 환경변수 예시
# 실제 배포 시 `gcloud run deploy --set-env-vars` 또는 Secret Manager 사용

# ── 서버 ──
PORT=8080
NODE_ENV=production

# ── 인증 (Wave 0 스켈레톤) ──
# HMAC 서명 검증용. pg_cron → Supabase secrets 에서 동일 키 사용
CLOUD_RUN_HMAC_SECRET=change-me-to-random-64-chars

# ── Supabase (결과 저장용) ──
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Gemini (Wave 2 에서 실제 호출 추가) ──
GEMINI_API_KEY=

# ── Claude (monthlyReport 이전 시) ──
ANTHROPIC_API_KEY=

# ── Firebase (잔류 호출용: RTDB 접근이 필요한 경우에만) ──
# service account JSON 을 Secret Manager 에서 주입
FIREBASE_PROJECT_ID=rabbitory-prod
