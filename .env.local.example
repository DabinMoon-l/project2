# Firebase 환경 변수 설정
# 이 파일을 복사하여 .env.local 파일을 생성하고, 실제 Firebase 프로젝트 값으로 교체하세요.
# Firebase Console (https://console.firebase.google.com)에서 프로젝트 설정 > 일반 > 내 앱에서 확인할 수 있습니다.

# Firebase API 키
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here

# Firebase 인증 도메인 (프로젝트ID.firebaseapp.com)
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# Firebase 프로젝트 ID
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Firebase Storage 버킷 (프로젝트ID.appspot.com)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Firebase 메시징 발신자 ID
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id

# Firebase 앱 ID
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Firebase Analytics 측정 ID (선택사항, Google Analytics 사용 시)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Firebase Cloud Messaging VAPID 키 (푸시 알림용)
# Firebase Console > 프로젝트 설정 > Cloud Messaging > 웹 푸시 인증서에서 확인
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key-here

# 네이버 로그인 (선택사항)
# Naver Developers (https://developers.naver.com)에서 앱 등록 후 확인
NEXT_PUBLIC_NAVER_CLIENT_ID=your-naver-client-id
NEXT_PUBLIC_NAVER_CALLBACK_URL=https://your-domain.com/api/auth/naver/callback

# Cloud Run PPTX 서비스 URL (PPT→PDF 변환용)
NEXT_PUBLIC_PPTX_CLOUD_RUN_URL=https://your-cloud-run-url.run.app

# ────────────────────────────────────────────────────────────
# Supabase (Phase 1 마이그레이션 — rankings/radar)
# https://supabase.com/dashboard/project/{ref}/settings/api
# ────────────────────────────────────────────────────────────

# Project URL (https://{project-ref}.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# anon public key — 클라이언트에 노출됨, RLS로 보호됨
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# service_role secret key — 서버 전용 (Cloud Functions, API Routes)
# ⚠️ 절대 클라이언트 번들에 포함되면 안 됨 (NEXT_PUBLIC_ 접두사 사용 금지)
# RLS를 bypass하므로 유출 시 DB 전체 접근 가능
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Feature flags — Supabase 읽기 소스 전환 (Phase 1-Week 3부터 활성화)
# 'true'면 Supabase, 'false' 또는 미설정이면 Firestore 유지
NEXT_PUBLIC_USE_SUPABASE_RANKINGS=false
NEXT_PUBLIC_USE_SUPABASE_RADAR=false
# Phase 2 Step 3: 도메인별 읽기 전환
NEXT_PUBLIC_USE_SUPABASE_ENROLLMENT=false
NEXT_PUBLIC_USE_SUPABASE_RABBITS=false
NEXT_PUBLIC_USE_SUPABASE_REVIEWS=false
NEXT_PUBLIC_USE_SUPABASE_POSTS=false

# Phase 2: 기본 org (파일럿 대학) UUID
# Supabase organizations 테이블의 'rabbitory-pilot' slug id
# SELECT id FROM organizations WHERE slug='rabbitory-pilot';
NEXT_PUBLIC_DEFAULT_ORG_ID=your-default-org-uuid

# ────────────────────────────────────────────────────────────
# Firebase 로컬 에뮬레이터 (로컬 개발 전용)
# ────────────────────────────────────────────────────────────
# true 로 켜면 auth/firestore/functions/storage/rtdb 모두 로컬 에뮬레이터로 연결됨.
# 실제 프로덕션 DB에 영향 없이 테스트 가능. 배포 시 반드시 false 또는 미설정.
# 사용법:
#   1) 터미널 A: firebase emulators:start
#   2) 터미널 B: npm run dev
#   3) 에뮬레이터 UI: http://localhost:4000
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
